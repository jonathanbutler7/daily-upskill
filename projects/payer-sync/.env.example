# Choose one:
# 1) DATABASE_URL only (recommended for Supabase)
# 2) component vars for local/postgres

# Optional: local | supabase (defaults to local)
DB_PROVIDER=local

# Preferred when available
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/payer_sync?sslmode=disable

# Optional private key overrides. Leave both unset to use the default user config dir.
# INGESTER_PRIVATE_KEY_PATH=/absolute/path/to/ingester_private_key.pem
# INGESTER_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY----- ..."

# Component variables (used when DATABASE_URL is empty)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=payer_sync

# For local postgres use disable; for Supabase use require
DB_SSLMODE=disable
